# Local Claude Code settings (per-user)
.claude/

# Crawler outputs that are regenerable / local-only
crawler/data/
crawler/enrich_data/
crawler/*.log

# Raw UG exports (personal libraries + per-run samples). Same rationale as
# crawler/private/ below: personal UG libraries are copyright grey-area and
# stay local — never auto-committed/shipped.
ug/ug-export-*.json

# Dev.to challenge article draft — local writing artifact, not part of the app.
DEV-SUBMISSION.md

# Shipped UG-bundle artifact — intentionally absent until we ship a
# cleanly-licensed demo bundle. crawler/build-private-bundle.py still
# regenerates it locally; just don't auto-commit Tommy's personal lib.
private-bundle.json

# Raw UG-import + on-device-enrichment source data. Used to live in this
# directory committed "for transparency" while the repo was private; now
# it's gitignored so personal libraries stay local. enrich-private.py +
# build-private-bundle.py still work on the local files.
crawler/private/

# Per-LLM enrichment checkpoint (OpenAI side). Used by crawler/enrich-gpt.py
# as an intermediate write target; the merged result lands in enrichment.json
# (which IS tracked + shipped). Local-only build artifact.
enrichment-gpt.json

# Enrichment per-letter lock files (per-process state, not data)
enrichment/*.lock

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node, if it ever sneaks in
node_modules/
