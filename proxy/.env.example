# Copy to .env (gitignored) and fill in. Server reads via process.env at startup.

# HTTP server
PORT=8787

# CORS allowlist (comma-separated). Localhost defaults are dev-only.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://aweussom.github.io

# LLM backend. Leave PROXY_API_BASE empty to run in stub mode (canned
# enrichment, no LLM calls, no credit burn, no need for a running model).
# When set, the proxy posts to {PROXY_API_BASE}/chat/completions with
# OpenAI-compatible JSON.
PROXY_API_BASE=
PROXY_MODEL=

# PROXY_API_KEY is OPTIONAL: only local Ollama lets you call without one.
# When non-empty, the proxy adds `Authorization: Bearer <key>` to the
# upstream request. Leave empty for local Ollama; required for Ollama
# Cloud or Mimo.
PROXY_API_KEY=

# Example real configs (uncomment ONE block):

# Local Ollama (RTX 5090 etc.) — no key needed:
# PROXY_API_BASE=http://localhost:11434/v1
# PROXY_MODEL=qwen3.6:latest

# Ollama Cloud:
# PROXY_API_BASE=https://ollama.com/v1
# PROXY_API_KEY=<your-ollama-cloud-key>
# PROXY_MODEL=deepseek-v4-pro:cloud

# Mimo V2 Pro:
# PROXY_API_BASE=https://api.mimo.xiaomi.com/v1
# PROXY_API_KEY=<your-mimo-key>
# PROXY_MODEL=mimo-v2-pro

# LLM call behavior (defaults match patterns from
# C:/devel/aweussom/python/evaluator + critique-llm):
PROXY_TEMPERATURE=0.7
PROXY_TIMEOUT_MS=600000
PROXY_RETRY_ATTEMPTS=3
PROXY_RETRY_BACKOFF_BASE_MS=5000
PROXY_RETRY_BACKOFF_MAX_MS=60000

# Cache file path (JSON, relative to proxy/ dir). Atomic tmp+rename writes
# on every put/del, full in-memory mirror at startup.
CACHE_PATH=enrichment-cache.json
